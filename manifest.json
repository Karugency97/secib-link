{
  "manifest_version": 2,
  "name": "SECIB Link",
  "version": "1.0.2",
  "description": "Panneau contextuel lié à l'API SECIB Neo — affiche les dossiers clients associés à l'expéditeur du mail sélectionné.",
  "author": "Cabinet NPL",
  "browser_specific_settings": {
    "gecko": {
      "id": "secib-link@cabinet-npl.fr",
      "strict_min_version": "115.0",
      "update_url": "https://raw.githubusercontent.com/Karugency97/secib-link/main/updates.json"
    }
  },
  "permissions": [
    "messagesRead",
    "messagesUpdate",
    "messagesTags",
    "accountsRead",
    "storage",
    "https://secibneo.secib.fr/*",
    "https://api.secib.fr/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "message_display_action": {
    "default_title": "SECIB Link — Dossiers liés à l'expéditeur",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "browser_action": {
    "default_title": "SECIB Link",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
